#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>

// Personal include

#include "includes/settings.dtsi"

&mt {
    require-prior-idle-ms = <30>;
    quick-tap-ms = <30>;
    hold-trigger-key-positions = <38>;
    hold-trigger-on-release;
    tapping-term-ms = <150>;
};

&lt {
    tapping-term-ms = <150>;
    quick-tap-ms = <30>;
    require-prior-idle-ms = <30>;
    hold-trigger-on-release;
    hold-trigger-key-positions = <39 40 37 36>;
};

/ {
    keymap {
        compatible = "zmk,keymap";

        default_layer {
            // -----------------------------------------------------------------------------------------
            // |  TAB |  Q  |  W  |  E  |  R  |  T  |   |  Y  |  U   |  I  |  O  |  P  | BSPC |
            // | CTRL |  A  |  S  |  D  |  F  |  G  |   |  H  |  J   |  K  |  L  |  ;  |  '   |
            // | SHFT |  Z  |  X  |  C  |  V  |  B  |   |  N  |  M   |  ,  |  .  |  /  | ESC  |
            //                    | GUI | LWR | SPC |   | ENT | RSE  | ALT |

            bindings = <
&kp TAB    &kp Q        &kp W           &kp E           &kp R             &kp T                     &kp Y        &kp U         &kp I            &kp O           &kp P                &kp BSPC
&kp LCTRL  &hm LCTRL A  &hm LEFT_ALT S  &hm LEFT_GUI D  &hm LEFT_SHIFT F  &kp G                     &kp H        &hm RSHFT J   &hm RIGHT_GUI K  &hm LEFT_ALT L  &hm RCTRL SEMICOLON  &kp SQT
&kp LSHFT  &kp Z        &kp X           &kp C           &kp V             &kp B                     &kp N        &kp M         &kp COMMA        &kp DOT         &kp FSLH             &kp ESC
                                        &lt 4 TAB       &lt 3 ESCAPE      &mt LEFT_COMMAND SPACE    &lt 2 ENTER  &lt 1 DELETE  &kp BACKSPACE
            >;
        };

        number-layer {
            // -----------------------------------------------------------------------------------------
            // |  TAB |  1  |  2  |  3  |  4  |  5  |   |  6  |  7  |  8  |  9  |  0  | BSPC |
            // | BTCLR| BT1 | BT2 | BT3 | BT4 | BT5 |   | LFT | DWN |  UP | RGT |     |      |
            // | SHFT |     |     |     |     |     |   |     |     |     |     |     |      |
            //                    | GUI |     | SPC |   | ENT |     | ALT |

            bindings = <
&kp TAB     &kp N1           &kp N2        &kp N3        &kp N4      &kp N5         &kp N6     &kp N7         &kp N8        &kp N9                &kp N0                 &kp BSPC
&bt BT_CLR  &kp EXCLAMATION  &kp AT_SIGN   &kp HASH      &kp DOLLAR  &kp PERCENT    &kp CARET  &kp AMPERSAND  &kp ASTERISK  &kp LEFT_PARENTHESIS  &kp RIGHT_PARENTHESIS  &trans
&kp LSHFT   &bt BT_SEL 0     &bt BT_SEL 1  &bt BT_SEL 2  &trans      &bt BT_CLR     &trans     &trans         &trans        &trans                &trans                 &trans
                                           &trans        &trans      &kp SPACE      &kp ENTER  &trans         &trans
            >;
        };

        arrow-layer {
            bindings = <
&trans  &trans  &trans            &kp LG(LS(TAB))       &kp LG(TAB)        &kp C_VOLUME_UP      &trans                  &trans                       &kp UP_ARROW  &trans                  &trans                  &trans
&trans  &trans  &trans            &kp LG(LA(UP_ARROW))  &trans             &kp C_VOLUME_DOWN    &trans                  &kp LEFT                     &kp DOWN      &kp RIGHT               &trans                  &trans
&trans  &trans  &kp LG(LA(LEFT))  &kp LG(LA(DOWN))      &kp LG(LA(RIGHT))  &kp K_MUTE           &hm RIGHT_GUI LG(LEFT)  &hm LEFT_GUI LA(LEFT_ARROW)  &trans        &hm LEFT_GUI LA(RIGHT)  &hm LEFT_GUI RG(RIGHT)  &trans
                                  &trans                &trans             &trans               &trans                  &trans                       &trans
            >;
        };

        symbol-layer {
            bindings = <
&trans  &trans           &kp LESS_THAN  &kp GREATER_THAN  &kp BACKSLASH  &kp GRAVE         &kp AMPERSAND  &trans      &kp LEFT_PARENTHESIS  &kp RIGHT_PARENTHESIS  &trans             &trans
&trans  &kp EXCLAMATION  &kp MINUS      &kp PLUS          &kp EQUAL      &kp HASH          &kp PIPE       &kp COLON   &kp LEFT_BRACKET      &kp RIGHT_BRACKET      &kp SINGLE_QUOTE   &trans
&trans  &kp GRAVE        &kp SLASH      &kp ASTERISK      &kp CARET      &kp UNDERSCORE    &kp TILDE      &kp DOLLAR  &kp LEFT_BRACE        &kp RIGHT_BRACE        &kp DOUBLE_QUOTES  &trans
                                        &trans            &trans         &kp SPACE         &kp ENTER      &trans      &trans
            >;
        };

        terminal-move {
            bindings = <
&trans  &trans            &kp LG(LA(UP_ARROW))  &trans             &trans  &trans    &trans  &trans  &trans  &trans  &trans  &trans
&trans  &kp LG(LA(LEFT))  &kp LG(LA(DOWN))      &kp LA(LG(RIGHT))  &trans  &trans    &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans            &trans                &trans             &trans  &trans    &trans  &trans  &trans  &trans  &trans  &trans
                                                &trans             &trans  &trans    &trans  &trans  &trans
            >;
        };

        raise_layer {
            // -----------------------------------------------------------------------------------------
            // |  TAB |  !  |  @  |  #  |  $  |  %  |   |  ^  |  &  |  *  |  (  |  )  | BSPC |
            // | CTRL |     |     |     |     |     |   |  -  |  =  |  [  |  ]  |  \  |  `   |
            // | SHFT |     |     |     |     |     |   |  _  |  +  |  {  |  }  | "|" |  ~   |
            //                    | GUI |     | SPC |   | ENT |     | ALT |

            bindings = <
&kp TAB    &kp EXCL  &kp AT  &kp HASH  &kp DLLR  &kp PRCNT    &kp CARET  &kp AMPS   &kp ASTRK  &kp LPAR  &kp RPAR  &kp BSPC
&kp LCTRL  &trans    &trans  &trans    &trans    &trans       &kp MINUS  &kp EQUAL  &kp LBKT   &kp RBKT  &kp BSLH  &kp GRAVE
&kp LSHFT  &trans    &trans  &trans    &trans    &trans       &kp UNDER  &kp PLUS   &kp LBRC   &kp RBRC  &kp PIPE  &kp TILDE
                             &kp LGUI  &trans    &kp SPACE    &kp RET    &trans     &kp RALT
            >;
        };
    };
};
